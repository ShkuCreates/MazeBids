generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  discordId     String         @unique
  username      String
  avatar        String?
  coins         Int            @default(0)
  totalEarned   Int            @default(0)
  totalSpent    Int            @default(0)
  role          String         @default("USER") // USER, ADMIN
  notifications Boolean        @default(false) // Discord DM notifications toggle
  referralCode  String?        @unique
  referredById  String?
  referredBy    User?          @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]         @relation("Referrals")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bids          Bid[]
  transactions  Transaction[]
  wonAuctions   Auction[]      @relation("Winner")
  completedTasks UserTask[]
  redemptions   Redemption[]
  userNotifications Notification[]
  auctionSubscriptions AuctionSubscription[]
  dailyReward   DailyReward?
  chatRewards   ChatReward[]

  @@index([notifications])
  @@index([role])
}

model BonusCode {
  id          String       @id @default(cuid())
  code        String       @unique
  reward      Int
  maxUses     Int          @default(1)
  usedCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  redemptions Redemption[]

  @@index([code])
}

model Redemption {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  bonusCodeId String
  bonusCode   BonusCode @relation(fields: [bonusCodeId], references: [id])
  redeemedAt  DateTime  @default(now())

  @@unique([userId, bonusCodeId])
}

model Auction {
  id              String         @id @default(cuid())
  title           String
  description     String
  product         String         @default("Digital Product")
  image           String?
  startTime       DateTime
  endTime         DateTime
  status          String         @default("UPCOMING") // UPCOMING, ACTIVE, ENDED, CANCELLED
  startingBid     Int            @default(0)
  currentBid      Int            @default(0)
  minBidIncrement Int            @default(100)
  highestBidderId String?
  highestBidder   User?          @relation("Winner", fields: [highestBidderId], references: [id])
  bids            Bid[]
  subscriptions   AuctionSubscription[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([startTime])
  @@index([endTime])
}

model AuctionSubscription {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, auctionId])
  @@index([auctionId])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Int
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])

  @@index([auctionId])
  @@index([timestamp])
  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Int
  type        String          // EARN, SPEND
  description String
  timestamp   DateTime        @default(now())
  userId      String
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String
  reward      Int
  type        String    // GAME, AD, QUIZ, SURVEY
  cooldown    Int       // in minutes
  users       UserTask[]

  @@index([type])
}

model UserTask {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  completedAt DateTime @default(now())

  @@index([userId])
  @@index([taskId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String    // BID_PLACED, OUTBID, WIN, COINS_EARNED, COINS_SPENT, REWARD, REFUND, SYSTEM
  message    String
  amount     Int?
  relatedId  String?   // auction_id or transaction_id
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  type        String   // IMAGE, VIDEO, LINK
  contentUrl  String   // URL to image/video or target link
  targetUrl   String?  // Optional link for image/video ads
  placement   String   // DASHBOARD, PROFILE, AUCTIONS, EARN, WATCH_ADS
  position    String   @default("TOP") // TOP, LEFT, RIGHT, BOTTOM
  size        String   @default("MEDIUM") // SMALL, MEDIUM, LARGE
  duration    Int?     // Duration in seconds (for video ads)
  reward      Int      @default(0) // Reward coins for watching
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([placement])
  @@index([position])
}

model DailyReward {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastClaimedAt   DateTime @default(now())
  streak          Int      @default(0)
  totalClaims     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ChatReward {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastRewardAt DateTime @default(now())
  messageCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId])
  @@index([userId])
}

model Cooldown {
  id          String   @id @default(cuid())
  userId      String
  command     String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([userId, command])
  @@index([userId])
  @@index([command])
}

